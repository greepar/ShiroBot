<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
        <HostPluginDir>..\QBotSharp\bin\Debug\$(TargetFramework)\plugins\$(AssemblyName)\</HostPluginDir>
        <Configurations>Debug;DebugPlugin;DebugAdapter;DebugAll;Release</Configurations>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\QBotSharp.SDK\QBotSharp.SDK.csproj"/>
        <PackageReference Include="ILRepack.Lib.MSBuild.Task" Version="2.0.44.1">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="EmbedIO" Version="3.5.2" />
        <PackageReference Include="PuppeteerSharp" Version="24.39.0" />
    </ItemGroup>


    <Target Name="RepackPlugin" AfterTargets="Publish" Condition="'$(Configuration)'=='Release'">
        <PropertyGroup>
            <MergedPluginFile>$(PublishDir)$(AssemblyName).merged.dll</MergedPluginFile>
        </PropertyGroup>

        <ItemGroup>
            <RepackInput Include="$(PublishDir)$(AssemblyName).dll" />
            <RepackDependency Include="$(PublishDir)*.dll"
                              Exclude="$(PublishDir)$(AssemblyName).dll;
                                       $(PublishDir)QBotSharp.SDK.dll;
                                       $(PublishDir)QBotSharp.Model.dll;
                                       $(PublishDir)System*.dll;
                                       $(PublishDir)mscorlib.dll;
                                       $(PublishDir)netstandard.dll" />
            <RepackInput Include="@(RepackDependency)" />
        </ItemGroup>

        <ILRepack
                TargetKind="Dll"
                OutputFile="$(MergedPluginFile)"
                InputAssemblies="@(RepackInput)"
                Internalize="true"
                Parallel="true"
                DebugInfo="true" />

        <Copy SourceFiles="$(MergedPluginFile)" DestinationFiles="$(PublishDir)$(AssemblyName).dll" OverwriteReadOnlyFiles="true" />
        <Delete Files="$(MergedPluginFile)" />
        <Delete Files="@(RepackDependency)" />
    </Target>

    <Target Name="CopyPluginToHost"
            AfterTargets="Build"
            Condition="'$(Configuration)'=='Debug' or '$(Configuration)'=='DebugPlugin' or '$(Configuration)'=='DebugAll'">
        <MakeDir Directories="$(HostPluginDir)" />

        <ItemGroup>
            <PluginDebugOutput Include="$(TargetDir)**\*"
                               Exclude="$(TargetDir)QBotSharp.SDK.dll;$(TargetDir)QBotSharp.SDK.pdb;$(TargetDir)QBotSharp.Model.dll;$(TargetDir)QBotSharp.Model.pdb" />
        </ItemGroup>

        <Copy SourceFiles="@(PluginDebugOutput)"
              DestinationFiles="@(PluginDebugOutput->'$(HostPluginDir)%(RecursiveDir)%(Filename)%(Extension)')"
              SkipUnchangedFiles="true" />
    </Target>
    
    
</Project>
